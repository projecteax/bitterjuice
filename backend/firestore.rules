rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthed() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isAuthed() && request.auth.uid == uid;
    }

    function isSquadMember(squadId) {
      return isAuthed() &&
        exists(/databases/$(database)/documents/squads/$(squadId)/members/$(request.auth.uid));
    }

    function isServer() {
      return false;
    }

    match /users/{uid} {
      allow read: if isSelf(uid);
      allow create: if isSelf(uid);
      allow update: if isSelf(uid);
      allow delete: if false;

      match /dailyCalibrations/{dateKey} {
        allow read, create, update: if isSelf(uid);
        allow delete: if false;
      }

      match /interestTags/{tagId} {
        allow read, create, update: if isSelf(uid);
        allow delete: if isSelf(uid);
      }
    }

    match /squads/{squadId} {
      allow read: if isSquadMember(squadId);
      allow create: if isAuthed();
      allow update, delete: if false;

      match /members/{uid} {
        allow read: if isSquadMember(squadId);
        allow create: if isSelf(uid);
        allow update, delete: if false;
      }
    }

    match /activityLogs/{logId} {
      allow read: if isAuthed() && isSquadMember(resource.data.squadId);
      allow create: if isAuthed() && isSquadMember(request.resource.data.squadId);
      allow update, delete: if false;
    }

    match /feedEvents/{eventId} {
      allow read: if isAuthed() && isSquadMember(resource.data.squadId);
      allow create, update, delete: if false;

      match /reactions/{reactionId} {
        allow read: if isAuthed() && isSquadMember(get(/databases/$(database)/documents/feedEvents/$(eventId)).data.squadId);
        allow create: if isAuthed() &&
          isSquadMember(get(/databases/$(database)/documents/feedEvents/$(eventId)).data.squadId);
        allow update, delete: if false;
      }
    }

    match /rewards/{rewardId} {
      allow read: if isAuthed() && (
        resource.data.ownerScope == "user" && resource.data.ownerId == request.auth.uid ||
        resource.data.ownerScope == "squad" && isSquadMember(resource.data.ownerId)
      );
      allow create: if isAuthed();
      allow update, delete: if false;
    }

    match /rewardPurchases/{purchaseId} {
      allow read: if isAuthed() && resource.data.buyerId == request.auth.uid;
      allow create, update, delete: if false;
    }

    match /nudges/{nudgeId} {
      allow read: if isAuthed() && isSquadMember(resource.data.squadId);
      allow create: if isAuthed() && isSquadMember(request.resource.data.squadId);
      allow update, delete: if false;
    }

    match /vetoCases/{caseId} {
      allow read: if isAuthed() && isSquadMember(resource.data.squadId);
      allow create: if isAuthed() && isSquadMember(request.resource.data.squadId);
      allow update, delete: if false;

      match /votes/{voteId} {
        allow read: if isAuthed() &&
          isSquadMember(get(/databases/$(database)/documents/vetoCases/$(caseId)).data.squadId);
        allow create: if isAuthed() &&
          isSquadMember(get(/databases/$(database)/documents/vetoCases/$(caseId)).data.squadId);
        allow update, delete: if false;
      }
    }

    match /xpLedger/{txId} {
      allow read: if isAuthed() && resource.data.userId == request.auth.uid;
      allow create, update, delete: if false;
    }

    match /badgeProgress/{badgeKey} {
      allow read: if isAuthed() && resource.data.userId == request.auth.uid;
      allow create, update, delete: if false;
    }

    match /badgeAwards/{awardId} {
      allow read: if isAuthed() && resource.data.userId == request.auth.uid;
      allow create, update, delete: if false;
    }

    match /mediaAssets/{assetId} {
      allow read: if isAuthed() && resource.data.ownerId == request.auth.uid;
      allow create: if isAuthed() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if false;
    }
  }
}
